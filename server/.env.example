# Database Connection
# Format: postgresql://username:password@host:port/database_name
# Example: postgresql://postgres:password@localhost:5432/educational_toy_centre
DATABASE_URL=

# Server Configuration
# Port where the backend server will run (e.g., 3000, 5000,)
PORT=

# Environment mode (development, production, testing)
NODE_ENV=

# Frontend URL for CORS configuration
# Example: http://localhost:5173 (for local development with Vite)
# Example: https://yourdomain.com (for production)
FRONTEND_URL=

# JWT Authentication Secrets
# Generate random secrets using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=

JWT_REFRESH_SECRET=

# JWT Token Expiration Times
# Examples: 15m, 1h, 7d (15 minutes, 1 hour, 7 days)
JWT_ACCESS_EXPIRES_IN=

JWT_REFRESH_EXPIRES_IN=

# Default Admin Account (for initial setup/seeding)
# Use a strong password for production
ADMIN_EMAIL=

ADMIN_PASSWORD=


EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM="Your Business Name <your_gmail@gmail.com>"